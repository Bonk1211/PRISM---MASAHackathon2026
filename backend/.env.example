# ILMU API key (YTL AI Labs Malaysia LLM) — drives /agent endpoint.
# Get one at: https://console.ilmu.ai/dashboard/api-keys
# OpenAI-compatible; cheapest model = ilmu-nemo-nano.
# Copy this file to backend/.env and fill in. backend/.env is gitignored.
ILMU_API_KEY=

# Optional: lock CORS origins for ngrok demos. Comma-separated.
# Default covers localhost dev. Override in prod / public tunnels.
# CORS_ALLOW_ORIGINS=http://localhost:5173,https://your-tunnel.ngrok-free.app

# Supabase — Phase 1 scoping session storage.
# Project ref: ncpvewfibvjyppoqrcbk. Keys in dashboard → Settings → API.
SUPABASE_URL=https://ncpvewfibvjyppoqrcbk.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: only needed if running backend/migrations/apply.py via psycopg2.
# Otherwise paste 001_scoping.sql into the Supabase SQL editor instead.
# SUPABASE_DB_PASSWORD=
