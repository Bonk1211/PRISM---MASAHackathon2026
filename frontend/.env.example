# PRISM Pipeline API base URL. No trailing slash.
# Local dev:    VITE_PIPELINE_API=http://localhost:8000
# Vercel prod:  VITE_PIPELINE_API=https://<your-backend>.up.railway.app
# Demo ngrok:   VITE_PIPELINE_API=https://<tunnel>.ngrok-free.app
#
# When unset or unreachable, the Pipeline screen falls back to cached mode
# and renders stages from key_numbers_python.json.
VITE_PIPELINE_API=http://localhost:8000

# Agent (ILMU LLM) endpoint.
# Defaults to ${VITE_PIPELINE_API}/agent if unset.
# VITE_AGENT_API=http://localhost:8000/agent

# Supabase — Phase 1 scoping session sync from the browser.
# Project ref: ncpvewfibvjyppoqrcbk. Anon key from dashboard → Settings → API.
# Anon key only — never put service-role key in a VITE_ var (browser-exposed).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Deploy-time vars (Vercel dashboard, NOT this file)
# ---------------------------------------------------------------------------
# All VITE_* vars are baked into the bundle at BUILD time, not runtime.
# Set them in Vercel → Project Settings → Environment Variables BEFORE
# triggering a build. Changing them requires a redeploy.
#
# Required at deploy: VITE_PIPELINE_API, VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY.